Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"DSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"A", "'"}], "[", "t", "]"}], "==", 
       RowBox[{"-", 
        FractionBox[
         RowBox[{"A", "[", "t", "]"}], "\[Tau]a"]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"B", "'"}], "[", "t", "]"}], "==", 
       RowBox[{
        FractionBox[
         RowBox[{"A", "[", "t", "]"}], "\[Tau]a"], "-", 
        FractionBox[
         RowBox[{"B", "[", "t", "]"}], "\[Tau]b"]}]}], ",", 
      RowBox[{
       RowBox[{"B", "[", "0", "]"}], "==", "0"}], ",", 
      RowBox[{
       RowBox[{"A", "[", "0", "]"}], "==", "1"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"A", "[", "t", "]"}], ",", 
      RowBox[{"B", "[", "t", "]"}]}], "}"}], ",", "t"}], "]"}], "//", 
  "FullSimplify"}]], "Input",
 CellChangeTimes->{{3.9839730478642616`*^9, 3.9839730566792774`*^9}, {
  3.9839731657408104`*^9, 3.9839731700312138`*^9}, {3.983973215161154*^9, 
  3.9839732671966743`*^9}, {3.983973343566622*^9, 3.983973386376873*^9}, {
  3.9841490674670067`*^9, 3.9841490717322426`*^9}, {3.984149170243559*^9, 
  3.984149186036579*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"f70a00ad-cec6-ee43-9778-52a37e92ce5a"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"A", "[", "t", "]"}], "\[Rule]", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"-", 
       FractionBox["t", "\[Tau]a"]}]]}], ",", 
    RowBox[{
     RowBox[{"B", "[", "t", "]"}], "\[Rule]", 
     FractionBox[
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"-", 
           FractionBox["t", "\[Tau]a"]}]], "-", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"-", 
           FractionBox["t", "\[Tau]b"]}]]}], ")"}], " ", "\[Tau]b"}], 
      RowBox[{"\[Tau]a", "-", "\[Tau]b"}]]}]}], "}"}], "}"}]], "Output",
 CellChangeTimes->{
  3.9839733873754044`*^9, 3.984149074298233*^9, {3.9841491725469017`*^9, 
   3.9841491866613064`*^9}},
 CellLabel->"Out[4]=",ExpressionUUID->"0d4d0d15-4123-4f41-a767-0f1099a007f0"]
}, Open  ]],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"A", "[", "t_", "]"}], ":=", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"-", 
      FractionBox["t", "\[Tau]a"]}]], 
    RowBox[{"(", "1", ")"}]}]}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"B", "[", "t_", "]"}], ":=", 
  FractionBox[
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", 
       FractionBox["t", "\[Tau]a"]}], "-", 
      FractionBox["t", "\[Tau]b"]}]], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"t", "/", "\[Tau]a"}]]}], "+", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"t", "/", "\[Tau]b"}]]}], ")"}], " ", "\[Tau]b", 
    RowBox[{"(", "1", ")"}], " "}], 
   RowBox[{"\[Tau]a", "-", "\[Tau]b"}]]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Tau]a", "=", "10"}], ";", 
  RowBox[{"\[Tau]b", "=", "5"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9839777031701145`*^9, 3.9839778150555687`*^9}, {
  3.983981311456854*^9, 3.98398131510524*^9}, {3.9839813615155888`*^9, 
  3.9839814038873024`*^9}, {3.9839821761091385`*^9, 3.983982178437458*^9}, {
