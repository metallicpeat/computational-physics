Notebook[{

Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{"DSolve", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"A", "'"}], "[", "t", "]"}], "==", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{"A", "[", "t", "]"}], "\[Tau]a"]}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"B", "'"}], "[", "t", "]"}], "==", 
      RowBox[{
       FractionBox[
        RowBox[{"A", "[", "t", "]"}], "\[Tau]a"], "-", 
       FractionBox[
        RowBox[{"B", "[", "t", "]"}], "\[Tau]b"]}]}], ",", 
     RowBox[{
      RowBox[{"B", "[", "0", "]"}], "==", "0"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"A", "[", "t", "]"}], ",", 
     RowBox[{"B", "[", "t", "]"}]}], "}"}], ",", "t"}], "]"}]], "Input",
 CellChangeTimes->{{3.9839730478642616`*^9, 3.9839730566792774`*^9}, {
  3.9839731657408104`*^9, 3.9839731700312138`*^9}, {3.983973215161154*^9, 
  3.9839732671966743`*^9}, {3.983973343566622*^9, 3.983973386376873*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"f70a00ad-cec6-ee43-9778-52a37e92ce5a"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"A", "[", "t", "]"}], "\[Rule]", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"-", 
        FractionBox["t", "\[Tau]a"]}]], " ", 
      TemplateBox[{"1"},
       "C"]}]}], ",", 
    RowBox[{
     RowBox[{"B", "[", "t", "]"}], "\[Rule]", 
     FractionBox[
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", 
          FractionBox["t", "\[Tau]a"]}], "-", 
         FractionBox["t", "\[Tau]b"]}]], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"t", "/", "\[Tau]a"}]]}], "+", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"t", "/", "\[Tau]b"}]]}], ")"}], " ", "\[Tau]b", " ", 
       TemplateBox[{"1"},
        "C"]}], 
      RowBox[{"\[Tau]a", "-", "\[Tau]b"}]]}]}], "}"}], "}"}]], "Output",
 CellChangeTimes->{3.9839733873754044`*^9},
 CellLabel->"Out[2]=",ExpressionUUID->"52515bce-c68b-d845-a245-a52776e32a8b"]
}, Open  ]],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"A", "[", "t_", "]"}], ":=", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"-", 
      FractionBox["t", "\[Tau]a"]}]], 
    RowBox[{"(", "10000", ")"}]}]}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"B", "[", "t_", "]"}], ":=", 
  FractionBox[
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", 
       FractionBox["t", "\[Tau]a"]}], "-", 
      FractionBox["t", "\[Tau]b"]}]], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"t", "/", "\[Tau]a"}]]}], "+", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"t", "/", "\[Tau]b"}]]}], ")"}], " ", "\[Tau]b", 
    RowBox[{"(", "10000", ")"}], " "}], 
   RowBox[{"\[Tau]a", "-", "\[Tau]b"}]]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Tau]a", "=", "10"}], ";", 
  RowBox[{"\[Tau]b", "=", "5"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9839777031701145`*^9, 3.9839778150555687`*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"fea3a68e-1785-2d4e-ad3c-6c387513fff0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
